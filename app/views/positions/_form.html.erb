<%= form_with model: [ @location, @position ] do |f| %>
  <%= render "devise/shared/error_messages", resource: @position %>

  <div class="mb-3">
    <%= f.label :name, "Position name", class: "form-label" %>
    <%= f.text_field :name, autofocus: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :section, "Division", class: "form-label" %>
    <%= f.select :section, position_section_options, { prompt: "Choose division" }, class: "form-select" %>
    <div class="form-text">Back of House covers kitchen and prep work. Front of House covers service and guest-facing work.</div>
  </div>

  <fieldset class="mb-4">
    <legend class="form-label mb-2">Color</legend>
    <div class="position-color-palette">
      <% Position::COLOR_PALETTE.each do |color| %>
        <label class="position-color-choice" title="<%= color %>">
          <%= f.radio_button :color, color, checked: @position.color.blank? ? color == Position::COLOR_PALETTE.first : @position.color == color, class: "position-color-input" %>
          <span class="position-color-swatch" style="--position-color: <%= color %>"></span>
        </label>
      <% end %>
    </div>
  </fieldset>

  <% if @position.persisted? %>
    <div class="form-check mb-4">
      <%= f.check_box :active, class: "form-check-input" %>
      <%= f.label :active, "Active", class: "form-check-label" %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center gap-2">
    <%= link_to "Back", location_positions_path(@location), class: "btn btn-outline-secondary" %>
    <%= f.submit @position.persisted? ? "Save Position" : "Add Position", class: "btn btn-primary" %>
  </div>
<% end %>
