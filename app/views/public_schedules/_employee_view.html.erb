<div class="card border-0 shadow-sm schedule-board">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered align-top mb-0 schedule-table schedule-table-seven schedule-table-striped">
        <thead>
          <tr>
            <% @week_dates.each do |date| %>
              <th class="text-center bg-white <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <% @week_dates.each do |date| %>
                <% shifts = @shifts_by_employee_and_date[[ employee.id, date ]] || [] %>
                <% cell_classes = ["schedule-cell"] %>
                <% cell_classes << "schedule-today-column" if schedule_today?(date) %>
                <% cell_classes << "schedule-cell-has-shift" if shifts.any? %>
                <% cell_style = shifts.any? ? "--position-color: #{shifts.first.position.display_color}" : nil %>
                <td class="<%= cell_classes.join(" ") %>" style="<%= cell_style %>">
                  <div class="d-grid gap-2">
                    <% shifts.each do |shift| %>
                      <%= render "public_schedules/shift_pill",
                            shift: shift,
                            title: shift.employee.display_name,
                            secondary_text: shift.position.name,
                            tertiary_text: shift_time_range(shift),
                            view_mode: "employees",
                            href: public_schedule_path(@account.public_schedule_slug, public_schedule_params(employee_id: shift.employee_id)) %>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>

          <% if @employees.empty? %>
            <tr>
              <td colspan="7" class="p-4 text-center text-secondary">No employees are available for this schedule view.</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
