<% if resource.errors.any? %>
  <div class="form-error-messages" role="status">
    <p class="fw-semibold mb-2">
      <%= pluralize(resource.errors.count, "error") %> prevented this form from being saved:
    </p>
    <ul class="mb-0">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
