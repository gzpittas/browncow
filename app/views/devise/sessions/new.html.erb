<% content_for :title, "Sign In" %>

<div class="auth-card card border-0 shadow-sm mx-auto">
  <div class="card-body p-4 p-md-5">
    <h1 class="h3 fw-semibold mb-2">Sign in to Schedule</h1>
    <p class="text-secondary mb-4">Use your manager account to open the scheduling dashboard.</p>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-3">
        <%= f.label :email, class: "form-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control" %>
      </div>

      <div class="mb-3">
        <%= f.label :password, class: "form-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "form-control" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="form-check mb-4">
          <%= f.check_box :remember_me, class: "form-check-input" %>
          <%= f.label :remember_me, class: "form-check-label" %>
        </div>
      <% end %>

      <%= f.submit "Sign In", class: "btn btn-primary w-100" %>
    <% end %>

    <div class="text-center mt-3">
      <span class="text-secondary">Need an account?</span>
      <%= link_to "Sign Up", new_user_registration_path, class: "ms-1" %>
    </div>
  </div>
</div>
