<%= form_with model: @location do |f| %>
  <%= render "devise/shared/error_messages", resource: @location %>

  <div class="mb-3">
    <%= f.label :name, "Location name", class: "form-label" %>
    <%= f.text_field :name, autofocus: true, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :address_line_1, "Address", class: "form-label" %>
    <%= f.text_field :address_line_1, class: "form-control" %>
  </div>

  <div class="row g-3">
    <div class="col-md-5">
      <%= f.label :city, class: "form-label" %>
      <%= f.text_field :city, class: "form-control" %>
    </div>

    <div class="col-md-3">
      <%= f.label :state, class: "form-label" %>
      <%= f.text_field :state, class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= f.label :postal_code, "Postal code", class: "form-label" %>
      <%= f.text_field :postal_code, class: "form-control" %>
    </div>
  </div>

  <% if @location.persisted? %>
    <div class="form-check mt-3">
      <%= f.check_box :active, class: "form-check-input" %>
      <%= f.label :active, "Active", class: "form-check-label" %>
    </div>
  <% end %>

  <div class="d-flex justify-content-between align-items-center gap-2 mt-4">
    <%= link_to "Back", locations_path, class: "btn btn-outline-secondary" %>
    <%= f.submit @location.persisted? ? "Save Location" : "Add Location", class: "btn btn-primary" %>
  </div>
<% end %>
