<% content_for :title, "Create Schedule" %>

<div class="auth-card card border-0 shadow-sm mx-auto">
  <div class="card-body p-4 p-md-5">
    <h1 class="h3 fw-semibold mb-2">Create weekly schedule</h1>
    <p class="text-secondary mb-4">Copy an existing week into a new Sunday-through-Saturday schedule for <%= @location.name %>, or start with a blank week.</p>

    <%= render "form" %>
  </div>
</div>
