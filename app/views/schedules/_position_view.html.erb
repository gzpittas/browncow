<div class="d-grid gap-4">
  <% @positions.each do |position| %>
    <section class="card border-0 shadow-sm schedule-board">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 fw-semibold mb-0 d-flex align-items-center gap-2">
          <span class="position-heading-swatch" style="--position-color: <%= position.display_color %>"></span>
          <%= position.name %>
        </h2>
        <span class="badge text-bg-light border"><%= pluralize(position.employees.active.count, "assigned employee") %></span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered align-top mb-0 schedule-table">
            <thead>
              <tr>
                <% @week_dates.each do |date| %>
                  <th class="text-center bg-white <%= "schedule-weekend-column" if schedule_weekend?(date) %> <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <tr>
                <% @week_dates.each do |date| %>
                  <% shifts = @shifts_by_position_and_date[[ position.id, date ]] || [] %>
                  <td class="schedule-cell <%= "schedule-weekend-column" if schedule_weekend?(date) %> <%= "schedule-today-column" if schedule_today?(date) %>"
                      data-schedule-quick-edit-target="cell"
                      data-action="click->schedule-quick-edit#cellClick dragenter->schedule-quick-edit#dragEnter dragover->schedule-quick-edit#dragOver dragleave->schedule-quick-edit#dragLeave drop->schedule-quick-edit#drop"
                      data-view-mode="positions"
                      data-shift-date="<%= date.iso8601 %>"
                      data-position-id="<%= position.id %>">
                    <div class="d-grid gap-2">
                      <% shifts.each do |shift| %>
                        <%= render "shift_pill", shift: shift, title: shift.employee.display_name, secondary_text: shift_time_range(shift), view_mode: "positions" %>
                      <% end %>
                      <% if @schedule.editable? %>
                        <%= link_to new_location_schedule_shift_path(@location, @schedule, position_id: position.id, shift_date: date, view: "positions", section: @section_mode),
                              class: "schedule-add-link",
                              data: { action: "click->schedule-quick-edit#rememberScheduleViewport", return_url: location_schedule_path(@location, @schedule, view: "positions", section: @section_mode) } do %>
                          <span class="schedule-add-link-label">+ Add <%= position.name %></span>
                        <% end %>
                      <% end %>
                    </div>
                  </td>
                <% end %>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  <% end %>

  <% if @positions.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5 text-center">
        <h2 class="h5 fw-semibold mb-2">Add positions first</h2>
        <p class="text-secondary mb-3">The position view groups the same saved shifts by active position.</p>
        <%= link_to "Add Positions", location_positions_path(@location), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
