<div class="d-grid gap-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="badge text-bg-light border"><%= @section_label %></div>
  </div>

  <% @positions.each do |position| %>
    <section class="card border-0 shadow-sm schedule-board">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 fw-semibold mb-0 d-flex align-items-center gap-2">
          <span class="position-heading-swatch" style="--position-color: <%= position.display_color %>"></span>
          <%= position.name %>
        </h2>
        <span class="badge text-bg-light border"><%= pluralize(position.employees.active.count, "assigned employee") %></span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered align-top mb-0 schedule-table">
            <thead>
              <tr>
                <% @week_dates.each do |date| %>
                  <th class="text-center bg-white <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <tr>
                <% @week_dates.each do |date| %>
                  <% shifts = @shifts_by_position_and_date[[ position.id, date ]] || [] %>
                  <td class="schedule-cell <%= "schedule-today-column" if schedule_today?(date) %>">
                    <div class="d-grid gap-2">
                      <% shifts.each do |shift| %>
                        <%= link_to edit_location_schedule_shift_path(@location, @schedule, shift, view: "positions", section: @section_mode), class: "shift-pill text-decoration-none", style: "--position-color: #{shift.position.display_color}" do %>
                          <span class="fw-semibold"><%= shift.employee.display_name %></span>
                          <span class="text-nowrap"><%= shift_time_range(shift) %></span>
                        <% end %>
                      <% end %>
                      <%= link_to "+ Add #{position.name}", new_location_schedule_shift_path(@location, @schedule, position_id: position.id, shift_date: date, view: "positions", section: @section_mode), class: "schedule-add-link" %>
                    </div>
                  </td>
                <% end %>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  <% end %>

  <% if @positions.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5 text-center">
        <h2 class="h5 fw-semibold mb-2">Add positions first</h2>
        <p class="text-secondary mb-3">The position view groups the same saved shifts by active position.</p>
        <%= link_to "Add Positions", location_positions_path(@location), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
