<% secondary_text = local_assigns[:secondary_text] %>

<div class="shift-pill shift-pill-with-actions <%= "shift-pill-single-row" if secondary_text.blank? %>" style="--position-color: <%= shift.position.display_color %>">
  <div class="shift-pill-main">
    <div class="shift-pill-top-row">
      <%= link_to edit_location_schedule_shift_path(@location, @schedule, shift, view: view_mode, section: @section_mode), class: "shift-pill-title-link text-decoration-none" do %>
        <span class="shift-pill-title fw-semibold"><%= title %></span>
      <% end %>
      <%= button_to location_schedule_shift_path(@location, @schedule, shift, view: view_mode, section: @section_mode),
            method: :delete,
            class: "shift-pill-delete",
            form_class: "shift-pill-delete-form",
            form: { onsubmit: "return confirm('Delete this shift?')" } do %>
        <span aria-hidden="true">&times;</span>
        <span class="visually-hidden">Delete shift</span>
      <% end %>
    </div>
    <% if secondary_text.present? %>
      <%= link_to edit_location_schedule_shift_path(@location, @schedule, shift, view: view_mode, section: @section_mode), class: "shift-pill-time-link text-decoration-none" do %>
        <span class="shift-pill-time text-nowrap"><%= secondary_text %></span>
      <% end %>
    <% end %>
  </div>
</div>
