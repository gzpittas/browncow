<div class="card border-0 shadow-sm schedule-board">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-bordered align-top mb-0 schedule-table schedule-table-seven">
        <thead>
          <tr>
            <% @week_dates.each do |date| %>
              <th class="text-center bg-white <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% @employees.each do |employee| %>
            <tr>
              <% @week_dates.each do |date| %>
                <% shifts = @shifts_by_employee_and_date[[ employee.id, date ]] || [] %>
                <% cell_classes = ["schedule-cell"] %>
                <% cell_classes << "schedule-today-column" if schedule_today?(date) %>
                <% cell_classes << "schedule-cell-has-shift" if shifts.any? %>
                <% cell_style = shifts.any? ? "--position-color: #{shifts.first.position.display_color}" : nil %>
                <td class="<%= cell_classes.join(" ") %>"
                    style="<%= cell_style %>"
                    data-schedule-quick-edit-target="cell"
                    data-action="click->schedule-quick-edit#cellClick dragenter->schedule-quick-edit#dragEnter dragover->schedule-quick-edit#dragOver dragleave->schedule-quick-edit#dragLeave drop->schedule-quick-edit#drop"
                    data-view-mode="employees"
                    data-shift-date="<%= date.iso8601 %>"
                    data-employee-id="<%= employee.id %>">
                  <div class="d-grid gap-2">
                    <% shifts.each do |shift| %>
                      <%= render "shift_pill", shift: shift, title: shift.employee.display_name, secondary_text: shift.position.name, tertiary_text: shift_time_range(shift), view_mode: "employees" %>
                    <% end %>
                    <%= link_to new_location_schedule_shift_path(@location, @schedule, employee_id: employee.id, shift_date: date, view: "employees", section: @section_mode),
                          class: "schedule-add-link",
                          data: { action: "click->schedule-quick-edit#rememberScheduleViewport", return_url: location_schedule_path(@location, @schedule, view: "employees", section: @section_mode) } do %>
                      <span class="schedule-add-link-context"><%= employee.display_name %></span>
                      <span class="schedule-add-link-label">+ Add Shift</span>
                    <% end %>
                  </div>
                </td>
              <% end %>
            </tr>
          <% end %>

          <% if @employees.empty? %>
            <tr>
              <td colspan="7" class="p-4 p-md-5 text-center">
                <h2 class="h5 fw-semibold mb-2">Add employees first</h2>
                <p class="text-secondary mb-3">The schedule grid will show active employees for this location.</p>
                <%= link_to "Add Employees", location_employees_path(@location), class: "btn btn-primary" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
