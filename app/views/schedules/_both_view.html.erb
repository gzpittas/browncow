<div class="d-grid gap-4">
  <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div class="badge text-bg-light border"><%= @section_label %></div>
  </div>

  <% @positions.each do |position| %>
    <% position_employees = @employees_by_position[position] || [] %>
    <section class="card border-0 shadow-sm schedule-board">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 fw-semibold mb-0 d-flex align-items-center gap-2">
          <span class="position-heading-swatch" style="--position-color: <%= position.display_color %>"></span>
          <%= position.name %>
        </h2>
        <span class="badge text-bg-light border"><%= pluralize(position_employees.count, "assigned employee") %></span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered align-top mb-0 schedule-table">
            <thead>
              <tr>
                <th class="schedule-name-column bg-white">Employee</th>
                <% @week_dates.each do |date| %>
                  <th class="text-center bg-white <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% position_employees.each do |employee| %>
                <tr>
                  <th class="schedule-name-column bg-white">
                    <span class="fw-semibold"><%= employee.display_name %></span>
                  </th>
                  <% @week_dates.each do |date| %>
                    <% shifts = @shifts_by_employee_position_and_date[[ employee.id, position.id, date ]] || [] %>
                    <td class="schedule-cell <%= "schedule-today-column" if schedule_today?(date) %>">
                      <div class="d-grid gap-2">
                        <% shifts.each do |shift| %>
                          <%= render "shift_pill", shift: shift, title: shift_time_range(shift), view_mode: "both" %>
                        <% end %>
                        <%= link_to "+ Add Shift", new_location_schedule_shift_path(@location, @schedule, employee_id: employee.id, position_id: position.id, shift_date: date, view: "both", section: @section_mode), class: "schedule-add-link" %>
                      </div>
                    </td>
                  <% end %>
                </tr>
              <% end %>

              <% if position_employees.empty? %>
                <tr>
                  <td colspan="8" class="p-4 text-center text-secondary">
                    No active employees are assigned to this position yet.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  <% end %>

  <% if @positions.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5 text-center">
        <h2 class="h5 fw-semibold mb-2">Add positions first</h2>
        <p class="text-secondary mb-3">The combined view groups schedules by position and then by employee.</p>
        <%= link_to "Add Positions", location_positions_path(@location), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
