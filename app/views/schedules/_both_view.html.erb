<div class="d-grid gap-4">
  <% @positions.each do |position| %>
    <% position_employees = @employees_by_position[position] || [] %>
    <section class="card border-0 shadow-sm schedule-board">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h2 class="h5 fw-semibold mb-0 d-flex align-items-center gap-2">
          <span class="position-heading-swatch" style="--position-color: <%= position.display_color %>"></span>
          <%= position.name %>
        </h2>
        <span class="badge text-bg-light border"><%= pluralize(position_employees.count, "assigned employee") %></span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-bordered align-top mb-0 schedule-table schedule-table-seven">
            <thead>
              <tr>
                <% @week_dates.each do |date| %>
                  <th class="text-center bg-white <%= "schedule-today-column" if schedule_today?(date) %>"><%= schedule_day_label(date) %></th>
                <% end %>
              </tr>
            </thead>
            <tbody>
              <% position_employees.each do |employee| %>
                <tr>
                  <% @week_dates.each do |date| %>
                    <% shifts = @shifts_by_employee_position_and_date[[ employee.id, position.id, date ]] || [] %>
                    <td class="schedule-cell <%= "schedule-today-column" if schedule_today?(date) %>"
                        data-schedule-quick-edit-target="cell"
                        data-action="click->schedule-quick-edit#cellClick dragenter->schedule-quick-edit#dragEnter dragover->schedule-quick-edit#dragOver dragleave->schedule-quick-edit#dragLeave drop->schedule-quick-edit#drop"
                        data-view-mode="both"
                        data-shift-date="<%= date.iso8601 %>"
                        data-employee-id="<%= employee.id %>"
                        data-position-id="<%= position.id %>">
                      <div class="d-grid gap-2">
                        <% shifts.each do |shift| %>
                          <%= render "shift_pill", shift: shift, title: shift.employee.display_name, secondary_text: shift_time_range(shift), view_mode: "both" %>
                        <% end %>
                        <%= link_to new_location_schedule_shift_path(@location, @schedule, employee_id: employee.id, position_id: position.id, shift_date: date, view: "both", section: @section_mode),
                              class: "schedule-add-link",
                              data: { action: "click->schedule-quick-edit#rememberScheduleViewport", return_url: location_schedule_path(@location, @schedule, view: "both", section: @section_mode) } do %>
                          <span class="schedule-add-link-context"><%= employee.display_name %></span>
                          <span class="schedule-add-link-label">+ Add Shift</span>
                        <% end %>
                      </div>
                    </td>
                  <% end %>
                </tr>
              <% end %>

              <% if position_employees.empty? %>
                <tr>
                  <td colspan="7" class="p-4 text-center text-secondary">
                    No active employees are assigned to this position yet.
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  <% end %>

  <% if @positions.empty? %>
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4 p-md-5 text-center">
        <h2 class="h5 fw-semibold mb-2">Add positions first</h2>
        <p class="text-secondary mb-3">The combined view groups schedules by position and then by employee.</p>
        <%= link_to "Add Positions", location_positions_path(@location), class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
