<% content_for :title, "Print #{schedule_week_label(@schedule)}" %>

<div class="print-toolbar screen-only">
  <button type="button" class="btn btn-primary" onclick="window.print()">Print</button>
  <%= link_to "Back to Schedule", location_schedule_path(@location, @schedule, view: @view_mode, section: @section_mode), class: "btn btn-outline-secondary" %>
</div>

<main class="print-page">
  <header class="print-header">
    <div>
      <div class="print-brand">Hickory Clock</div>
      <h1><%= @location.account.name %></h1>
      <p><%= @location.name %></p>
    </div>
    <div class="print-meta">
      <div><%= schedule_print_week_label(@schedule) %></div>
      <strong><%= @view_mode == "employees" ? "Schedule by Employee" : "Schedule by Position" %></strong>
      <div><%= @section_label %></div>
    </div>
  </header>

  <% if @schedule.notes.present? %>
    <section class="print-notes">
      <strong>Notes:</strong>
      <%= simple_format(@schedule.notes, {}, wrapper_tag: "span") %>
    </section>
  <% end %>

  <% if @view_mode == "employees" %>
    <%= render "print_employee_view" %>
  <% else %>
    <%= render "print_position_view" %>
  <% end %>
</main>
